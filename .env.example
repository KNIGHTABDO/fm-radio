# Environment Variables

# GitHub Copilot / GitHub Models (multi-model)
# Use a GitHub token with access to Copilot.
GITHUB_COPILOT_TOKEN=
GITHUB_COPILOT_MODEL=

# Deepgram TTS API - Get from https://console.deepgram.com/
DEEPGRAM_API_KEY=

# Spotify Developer App - Create at https://developer.spotify.com/dashboard/
NEXT_PUBLIC_SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# NextAuth
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://127.0.0.1:3000
